---
// Integrations Section.
//
// REFRAMED for the v0.11 ICP (devs pairing with AI agents). Roady is NOT a
// Jira / Linear replacement and the ICP doc explicitly excludes hand-managed
// PM-tool shops. So plugins live here as a "bring your existing tracker
// along" sub-section, not as the headline. The story: Roady runs *in front*
// of these tools for the AI-paired workflow; the plugins keep your team's
// existing tracker in sync as a side effect.
---

<section id="integrations" class="py-24 bg-gradient-to-b from-violet-900/10 to-[#0B0E14]">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-12">
      <span class="inline-block px-4 py-1 mb-4 text-xs font-semibold uppercase tracking-widest text-emerald-400 bg-emerald-500/10 rounded-full border border-emerald-500/20">
        Bring your existing tracker along
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Already on Linear, Jira, or GitHub Issues?</h2>
      <p class="text-gray-400 max-w-2xl mx-auto">
        Roady is not a replacement for those. It runs <em>in front</em> of them for the AI-paired
        workflow &mdash; your agent reads and writes Roady, and a plugin keeps the human team's
        existing tracker in sync as a side effect. No migration, no rip-and-replace.
      </p>
    </div>

    <!-- Compact plugin catalogue (one row, no Official Plugin badging) -->
    <div class="glass p-8 rounded-3xl mb-8">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6 items-center justify-items-center text-center">
        <div class="flex flex-col items-center">
          <div class="w-10 h-10 bg-indigo-500/20 rounded-lg flex items-center justify-center mb-2">
            <svg class="w-6 h-6 text-indigo-400" viewBox="0 0 24 24" fill="currentColor"><path d="M3 7.5L12 2l9 5.5v9L12 22l-9-5.5v-9zm9 11.25l6.75-4.125V9.375L12 13.5l-6.75-4.125v5.25L12 18.75z"/></svg>
          </div>
          <span class="text-sm text-gray-300">Linear</span>
        </div>
        <div class="flex flex-col items-center">
          <div class="w-10 h-10 bg-blue-500/20 rounded-lg flex items-center justify-center mb-2">
            <svg class="w-6 h-6 text-blue-400" viewBox="0 0 24 24" fill="currentColor"><path d="M11.53 2c0 2.4 1.97 4.35 4.35 4.35h1.78v1.7c0 2.4 1.94 4.34 4.34 4.35V2.84a.84.84 0 0 0-.84-.84h-9.63zm-5.75 5.75c0 2.4 1.97 4.35 4.35 4.35h1.78v1.7c0 2.4 1.94 4.34 4.34 4.35V8.6a.84.84 0 0 0-.84-.85H5.78zm-5.75 5.75c0 2.4 1.97 4.35 4.35 4.35h1.78v1.7c0 2.4 1.94 4.34 4.34 4.35v-9.56a.84.84 0 0 0-.84-.84H.03z"/></svg>
          </div>
          <span class="text-sm text-gray-300">Jira</span>
        </div>
        <div class="flex flex-col items-center">
          <div class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center mb-2">
            <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          </div>
          <span class="text-sm text-gray-300">GitHub Issues</span>
        </div>
        <div class="flex flex-col items-center">
          <div class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center mb-2">
            <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M4.459 4.208c.746.606 1.026.56 2.428.466l13.215-.793c.28 0 .047-.28-.046-.326L17.86 1.968c-.42-.326-.98-.7-2.055-.607L3.01 2.295c-.466.046-.56.28-.374.466zm.793 3.08v13.904c0 .747.373 1.027 1.214.98l14.523-.84c.841-.046.935-.56.935-1.167V6.354c0-.606-.233-.933-.748-.886l-15.177.887c-.56.047-.747.327-.747.933zm14.337.745c.093.42 0 .84-.42.888l-.7.14v10.264c-.608.327-1.168.514-1.635.514-.748 0-.935-.234-1.495-.933l-4.577-7.186v6.952l1.448.327s0 .84-1.168.84l-3.22.186c-.094-.186 0-.653.327-.746l.84-.233V9.854L7.822 9.76c-.094-.42.14-1.026.793-1.073l3.456-.233 4.764 7.279v-6.44l-1.215-.14c-.093-.514.28-.886.747-.933z"/></svg>
          </div>
          <span class="text-sm text-gray-300">Notion</span>
        </div>
        <div class="flex flex-col items-center">
          <div class="w-10 h-10 bg-sky-500/20 rounded-lg flex items-center justify-center mb-2">
            <svg class="w-6 h-6 text-sky-400" viewBox="0 0 24 24" fill="currentColor"><path d="M21 0H3C1.343 0 0 1.343 0 3v18c0 1.656 1.343 3 3 3h18c1.656 0 3-1.344 3-3V3c0-1.657-1.344-3-3-3zM10.44 18.18c0 .795-.645 1.44-1.44 1.44H4.56c-.795 0-1.44-.645-1.44-1.44V4.56c0-.795.645-1.44 1.44-1.44H9c.795 0 1.44.645 1.44 1.44v13.62zm10.44-6c0 .794-.645 1.44-1.44 1.44h-4.44c-.795 0-1.44-.646-1.44-1.44V4.56c0-.795.645-1.44 1.44-1.44h4.44c.795 0 1.44.645 1.44 1.44v7.62z"/></svg>
          </div>
          <span class="text-sm text-gray-300">Trello</span>
        </div>
        <div class="flex flex-col items-center">
          <div class="w-10 h-10 bg-rose-500/20 rounded-lg flex items-center justify-center mb-2">
            <svg class="w-6 h-6 text-rose-400" viewBox="0 0 24 24" fill="currentColor"><path d="M18.78 12.653c-2.587 0-4.685 2.098-4.685 4.686 0 2.587 2.098 4.685 4.685 4.685 2.588 0 4.686-2.098 4.686-4.685 0-2.588-2.098-4.686-4.686-4.686zm-13.56 0c-2.587 0-4.686 2.098-4.686 4.686 0 2.587 2.099 4.685 4.686 4.685 2.588 0 4.686-2.098 4.686-4.685 0-2.588-2.098-4.686-4.686-4.686zm11.466-4.676c0 2.588-2.098 4.686-4.686 4.686-2.587 0-4.685-2.098-4.685-4.686C7.315 5.39 9.413 3.29 12 3.29c2.588 0 4.686 2.099 4.686 4.687z"/></svg>
          </div>
          <span class="text-sm text-gray-300">Asana</span>
        </div>
      </div>
      <p class="text-center text-sm text-gray-500 mt-6">
        Pluggable syncers via HashiCorp <code class="mono text-gray-400">go-plugin</code>.
        Build your own &mdash; <a href="https://github.com/felixgeelhaar/roady/tree/main/cmd" class="text-violet-400 underline">reference plugins on GitHub</a>.
      </p>
    </div>
  </div>
</section>
